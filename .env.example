# Kare Docker — configuration template
# Copy to .env and edit before running docker compose up.

# ── Profile ────────────────────────────────────────────────────────────────────
# "ollama"  — include built-in Ollama LLM server (~10 GB image download).
#             Remove if you have your own Ollama/vLLM/cloud LLM running elsewhere.
# "medium"  — include BGE-M3 embedding service (vector search, ~3 GB).
# "full"    — include BGE-M3 + voice bridge (STT/TTS).
# Combine with commas. Run setup.sh (Linux/macOS) or setup.ps1 (Windows) to auto-detect.
COMPOSE_PROFILES=ollama,medium

# ── Domain for HTTPS (Caddy) ──────────────────────────────────────────────────
# Your DuckDNS domain, e.g. kaare.duckdns.org
# Caddy automatically obtains a Let's Encrypt certificate.
# Without a domain: use "localhost" for local HTTP access.
KAARE_DOMAIN=localhost

# ── HuggingFace (optional, for image generation and cloud LLM) ───────────────
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Brave Search (optional, for web search) ───────────────────────────────────
# BRAVE_API_KEY=BSAxxxxxxxxxxxxxxxxxxxxxxxxx
